digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.2, nodesep=0.4, ranksep=0.55, fontname="Arial"];
  node [shape=ellipse, style="filled", fontname="Arial", fontsize=9, color="#2F5D7C", fillcolor="#EAF3F8"];
  edge [color="#56788A", arrowsize=0.7, fontname="Arial", fontsize=8];
  pending -> confirmed [label="manual confirmation"];
  confirmed -> checked [label="customer arrives"];
  checked -> progress [label="start exam"];
  progress -> completed [label="save result"];
  confirmed -> rescheduled;
  rescheduled -> confirmed;
  pending -> cancelled;
  confirmed -> cancelled;
  confirmed -> noshow [label="missed slot"];
  pending [label="pending"];
  confirmed [label="confirmed"];
  checked [label="checked_in"];
  progress [label="in_progress"];
  completed [label="completed", fillcolor="#E8F5E9", color="#4C7A4C"];
  rescheduled [label="rescheduled", fillcolor="#FFF4DD", color="#A97822"];
  cancelled [label="cancelled", fillcolor="#FDECEC", color="#A84A4A"];
  noshow [label="no_show", fillcolor="#F3F3F3", color="#777777"];
}
