digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.2, nodesep=0.4, ranksep=0.55, fontname="Arial"];
  node [shape=ellipse, style="filled", fontname="Arial", fontsize=10, color="#2F5D7C", fillcolor="#EAF3F8"];
  edge [color="#56788A", arrowsize=0.7, fontname="Arial", fontsize=8];
  draft -> pending [label="submit"];
  pending -> verified [label="valid"];
  pending -> needs [label="missing / unclear"];
  pending -> rejected [label="invalid"];
  needs -> pending [label="customer updates"];
  verified -> expired [label="expiry date reached"];
  pending -> overdue [label="SLA exceeded"];
  overdue -> pending [label="reassigned"];
  draft [label="draft"];
  pending [label="pending_review"];
  needs [label="needs_update"];
  verified [label="verified", fillcolor="#E8F5E9", color="#4C7A4C"];
  rejected [label="rejected", fillcolor="#FDECEC", color="#A84A4A"];
  expired [label="expired", fillcolor="#F3F3F3", color="#777777"];
  overdue [label="overdue", fillcolor="#FFF4DD", color="#A97822"];
}
